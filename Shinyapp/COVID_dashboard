```{r setup, include=FALSE}
knitr::opts_chunk$set(echo = TRUE)
library(tidyverse)
library(lubridate)
library(ggplot2)
library(plotly)
library(leaflet)
library(sp)
library(flexdashboard)
library(corrplot)
 gen_covid <- read_csv("data/DC_COVID19.csv") 
new_df <- gen_covid %>%
  gather(`Number of Deaths`, `Cleared From Isolation`, key = `type`, value = `frequency`)
colnames(new_df)[4] <- "dates"


new_df2 <- gen_covid %>%
  gather(`Total Positives`, `Number of Deaths`, `Cleared From Isolation`, key = `type`, value = `frequency`)
colnames(new_df2)[3] <- "dates"
```




